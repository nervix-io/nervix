    'geoip_city' = device_location_checked_events.geoip_city,
    'geoip_lat' = device_location_checked_events.geoip_lat,
    'geoip_lon' = device_location_checked_events.geoip_lon,
    'geoip_geohash' = device_location_checked_events.geoip_geohash,
    'nearest_hub' = device_location_checked_events.nearest_hub,
    'distance_to_hub_km' = device_location_checked_events.distance_to_hub_km,
    'edge_name' = device_location_checked_events.edge_name,
    'edge_region' = device_location_checked_events.edge_region,
    'edge_site_tier' = device_location_checked_events.edge_site_tier,
    'edge_lat' = device_location_checked_events.edge_lat,
    'edge_lon' = device_location_checked_events.edge_lon,
    'distance_to_edge_km' = device_location_checked_events.distance_to_edge_km
  }
  LOCATION 's3://nervix-iceberg/tables/datalake_device_locations'
  CATALOG lakehouse_catalog
  ON MESSAGE ERROR LOG
  ON GENERAL ERROR LOG
  FLUSH EACH 10s MAX BATCH SIZE 8MiB
  COMMIT EACH 1m MAX SIZE 512MiB;

