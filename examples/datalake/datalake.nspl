CREATE DETACHED EMITTER iceberg_disconnect_device_only_events
  FROM disconnect_events_device_only
  TO ICEBERG ON S3 s3_lakehouse TABLE datalake_disconnect_device_only_events
  VALUES {
    'event_id' = disconnect_events_device_only.event_id,
    'tenant_id' = disconnect_events_device_only.tenant_id,
    'device_id' = disconnect_events_device_only.device_id,
    'session_id' = disconnect_events_device_only.session_id,
    'edge_id' = disconnect_events_device_only.edge_id,
    'disconnect_kind' = disconnect_events_device_only.disconnect_kind,
    'device_event_id' = disconnect_events_device_only.device_event_id,
    'edge_event_id' = disconnect_events_device_only.edge_event_id,
    'device_disconnected_at' = disconnect_events_device_only.device_disconnected_at,
    'edge_disconnected_at' = disconnect_events_device_only.edge_disconnected_at,
    'source_ip' = disconnect_events_device_only.source_ip,
    'device_lat' = disconnect_events_device_only.device_lat,
    'device_lon' = disconnect_events_device_only.device_lon,
    'battery_pct' = disconnect_events_device_only.battery_pct,
    'firmware' = disconnect_events_device_only.firmware,
    'edge_name' = disconnect_events_device_only.edge_name,
    'protocol' = disconnect_events_device_only.protocol,
    'edge_region' = disconnect_events_device_only.edge_region,
